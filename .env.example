APP_NAME=Learning App Service
API_V1_PREFIX=/api/v1
SECRET_KEY=please-change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
TOKEN_ALGORITHM=HS256
BACKEND_CALLBACK_TOKEN=
BACKEND_TASK_LEASE_SECONDS=300
DATABASE_URL=mysql+pymysql://root:123456@127.0.0.1:3306/learning_app?charset=utf8mb4

# --- AI Agent Worker ---
AI_MODE=mock                          # mock | real
VIVO_APP_KEY=                         # vivo platform API key (required for real mode)
VIVO_API_URL=https://api-ai.vivo.com.cn/v1/chat/completions
AI_MODEL=Volc-DeepSeek-V3.2
AI_TIMEOUT=60                         # LLM request timeout in seconds
AI_MAX_RETRIES=3                      # retry count for recoverable errors
AI_WORKER_ID=worker-a                 # unique worker identifier
AI_POLL_INTERVAL=5                    # seconds between task polls

